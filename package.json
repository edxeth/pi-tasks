{
  "name": "pi-tasks",
  "version": "1.2.1",
  "description": "Session-scoped task system for pi with a live widget, reminders, and atomic batch updates.",
  "author": "edxeth",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/edxeth/pi-tasks.git"
  },
  "homepage": "https://github.com/edxeth/pi-tasks#readme",
  "bugs": {
    "url": "https://github.com/edxeth/pi-tasks/issues"
  },
  "keywords": [
    "pi-package",
    "pi",
    "pi-extension",
    "task",
    "tasks",
    "todo",
    "coordination"
  ],
  "files": [
    "src",
    "dist",
    "README.md",
    "LICENSE"
  ],
  "peerDependencies": {
    "@earendil-works/pi-ai": "*",
    "@earendil-works/pi-coding-agent": "*",
    "@earendil-works/pi-tui": "*",
    "typebox": "*"
  },
  "scripts": {
    "build": "tsc",
    "prepublishOnly": "npm run typecheck && npm run test && npm run build",
    "test": "vitest run",
    "test:watch": "vitest",
    "typecheck": "tsc --noEmit"
  },
  "devDependencies": {
    "@earendil-works/pi-ai": "^0.75.4",
    "@earendil-works/pi-coding-agent": "^0.75.4",
    "@earendil-works/pi-tui": "^0.75.4",
    "@types/node": "^20.0.0",
    "typebox": "^1.1.33",
    "typescript": "^5.0.0",
    "vitest": "^4.0.18"
  },
  "pi": {
    "extensions": [
      "./src/index.ts"
    ]
  },
  "trustedDependencies": [
    "koffi",
    "protobufjs"
  ]
}